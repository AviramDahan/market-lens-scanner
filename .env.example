MARKET_LENS_URL=https://market-lens-scanner.onrender.com/?v=latest
MARKET_LENS_EMAIL=you@example.com
MARKET_LENS_PASSWORD=change-me
MARKET_LENS_EXCEL_PATH=C:\Users\User\Downloads\market_lens_agent_portfolio_budget_100k.xlsx
MARKET_LENS_UNIVERSE=smart-universe
MARKET_LENS_TICKERS=
MARKET_LENS_ANALYSIS_PERIOD=6mo
MARKET_LENS_MIN_RR=2
MARKET_LENS_HEADLESS=true

# Agent Smart Universe scan breadth. Keep these configurable before moving to batching.
MARKET_LENS_AGENT_UNIVERSE_TARGET=100
MARKET_LENS_AGENT_UNIVERSE_POOL=100
MARKET_LENS_AGENT_MAX_PER_SECTOR=15
MARKET_LENS_AGENT_SCAN_BATCH_SIZE=20

# Required by the deployed web app for Supabase login.
# Configure these on Render for the public site.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-supabase-anon-or-publishable-key
# SUPABASE_ANON_KEY is also accepted as a fallback if your host uses that name.

# Agent entry-quality gates. Defaults are conservative and configurable.
MARKET_LENS_BULL_MIN_SETUP_SCORE=0.40
MARKET_LENS_NEUTRAL_MIN_SETUP_SCORE=0.50
MARKET_LENS_MIN_PRIMARY_NET_RR=0.80
MARKET_LENS_PREFERRED_PRIMARY_NET_RR=1.00
MARKET_LENS_PRIMARY_RR_WEIGHT=0.80
MARKET_LENS_STRETCH_RR_WEIGHT=0.20
MARKET_LENS_MIN_TARGET1_ATR_DISTANCE=0.75
MARKET_LENS_REQUIRE_ENTRY_CONFIRMATION=true
MARKET_LENS_STOP_COOLDOWN_DAYS=3
MARKET_LENS_COOLDOWN_EXCEPTION_SETUP_SCORE=0.60
MARKET_LENS_COOLDOWN_EXCEPTION_NET_RR1=1.20
MARKET_LENS_ALLOW_BUY_OUTSIDE_REGULAR_HOURS=false

# Agent chart retention. Keep repo size low by saving only actionable/debug charts.
MARKET_LENS_SAVE_REJECTED_CHARTS=false
MARKET_LENS_REJECTED_CHART_LIMIT=5
MARKET_LENS_REJECTED_CHART_MIN_SCORE=0.40

# Server-side live TP/SL monitor trigger. Configure on Render only, never in frontend code.
GITHUB_ACTIONS_TRIGGER_TOKEN=github-token-with-actions-workflow-scope
GITHUB_ACTIONS_REPOSITORY=AviramDahan/market-lens-scanner
GITHUB_POSITION_MONITOR_WORKFLOW=market-lens-position-monitor.yml
GITHUB_ACTIONS_REF=main
MARKET_LENS_MONITOR_CRON_SECRET=change-me-long-random-secret
MARKET_LENS_MONITOR_TRIGGER_GLOBAL_COOLDOWN_SECONDS=60
MARKET_LENS_MONITOR_TRIGGER_EVENT_COOLDOWN_SECONDS=300
